# CODUKU Microservice Environment Configuration
# Copy this to .env and fill in your actual values
# Last Updated: 2026-04-01

# ===== CORE SETTINGS =====
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# ===== JWT & SECURITY =====
JWT_SECRET=your-super-secret-jwt-key-change-in-production-12345
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ===== SUPABASE (Auth & Database) =====
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_ANON_KEY=your_supabase_anon_key

# ===== POSTGRESQL =====
POSTGRES_URL=postgresql://postgres:postgres@postgres:5432/coduku
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=coduku

# ===== REDIS =====
REDIS_URL=redis://redis:6379/0
UPSTASH_REDIS_URL=redis://redis:6379/0

# ===== JUDGE0 CODE EXECUTION =====
JUDGE0_API_URL=http://judge0:2358
JUDGE0_WORKERS=4
JUDGE0_CPU_TIME_LIMIT=5
JUDGE0_MEMORY_LIMIT=262144

# ===== OPENAI & AI SERVICES =====
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4-turbo

# ===== CHROMADB VECTOR STORE =====
CHROMADB_URL=http://chromadb:8000

# ===== FRONTEND =====
REACT_APP_API_URL=http://localhost/api/v1
REACT_APP_WS_URL=ws://localhost/ws
REACT_APP_PUBLIC_URL=http://localhost:3000

# ===== CORS =====
CORS_ORIGINS=http://localhost:3000,http://localhost:80

# ===== DEBUG (Set to false in production) =====
JUDGE0_FORCE_MOCK=false
MONGO_FORCE_DISABLE=false

